
process {
  executor = 'slurm'
  queue    = 'your_queue'     // change as needed
  clusterOptions = ''
  // resources—can be overridden per label or process
  cpus    = { params.max_cpus }
  memory  = { params.max_mem }
  time    = { params.max_time }
}

docker.enabled      = false
singularity.enabled = true
singularity.autoMounts = true

workDir = 'work'        // default; you can set a shared scratch

