params {
  // Set to null so the user is forced to provide an input,
  // or it defaults to an empty string to avoid errors.
  reads            = ""
  outdir           = "results"

  // New Control Flags
  run_trimgalore   = true
  run_ribodetector = true
  run_sortmerna    = true
  run_kraken2      = true
  run_parabricks   = true
  run_star         = false
  run_featurecounts= false
  run_salmon       = false
  salmon_index     = null
  run_dge          = false
  dge_tool         = "deseq2"
  dge_control      = "control"
  dge_treatment    = "treatment"
  dge_comparison_name = "treatment_vs_control"
  batch_method     = "none"
  batch_col        = null
  dge_p_threshold  = 0.05
  dge_fc_threshold = 1.0
  group_col        = "group"
  covariates       = "null"
  dge_run_go       = false    // Run GO enrichment in Nextflow DGE
  dge_run_gsea     = false    // Run GSEA enrichment in Nextflow DGE
  dge_organism_db  = "org.Hs.eg.db"
  dge_ontology     = "BP"
  dge_keytype      = "SYMBOL"
  dge_use_biomart  = false
  dge_autoinstall  = true     // Allow R to attempt auto-installing missing packages
  http_proxy       = null     // Set if your environment requires a proxy for internet access

  // --- DGE-only inputs (NEW) ---
  // If both are provided AND --run_dge true, main.nf can run DGE without --reads
  dge_counts   = null   // path to featureCounts output file (tsv/txt)
  dge_metadata = null   // path to metadata CSV with columns: sample,group

  // Parabricks Options
  parabricks_index = "/home/baseripper/programs/MetaLL/MetaLL_0.0.1/assets/GRCh38_indexed/" // This must be a directory
  genome_fasta     = "/home/baseripper/programs/MetaLL/MetaLL_0.0.1/assets/GRCh38.primary_assembly.genome.fa"
  genome_gtf       = "/home/baseripper/programs/MetaLL/MetaLL_0.0.1/assets/GCF_000001405.40_GRCh38.p14_genomic.gtf"

  // STAR Options
  star_index       = "/home/baseripper/programs/MetaLL/MetaLL_0.0.1/assets/GRCh38_indexed/" // Update to your STAR index path

  // Kraken2 Options
  kraken2_db       = "/media/baseripper/volume_28TB_2/k2_standard_20251015" // Update to your path
  k2_confidence    = 0.0        // Confidence score threshold [0-1]
  k2_min_hit_groups= 2

  // Bracken Options
  bracken_level    = "S"
  bracken_read_len = 150
  bracken_threshold= 10

  // SortMeRNA Options
  smr_db_dir       = "/home/baseripper/Documents/rnaSeq-data/rRNA_databases"
  smr_num_alignments = 1        // Report first alignment per read (standard for filtering)
  smr_evalue       = 1          // E-value threshold
  smr_mismatch     = 2          // Max mismatches allowed
  smr_coverage     = 0.97       // Min coverage required for alignment
  smr_rand_seed    = 1          // Seed for reproducibility

  samplesheet= null

  // RiboDetector Options
  rd_len           = 150        // Read length (must match trained model: 50, 70, 100, 150)
  rd_model         = 'norrna'   // Model type: 'norrna' (recall) or 'rrna' (precision)
  rd_gpu_mem       = 20         // GPU memory limit in GB (sets batch size)
  rd_chunk_size    = null        // Number of sequences to process per chunk
  rd_threads       = 16         // Threads for file I/O

  // Trim Galore Options
  tg_quality       = 20         // Trim low-quality ends (Phred score)
  tg_fastqc        = true       // Run FastQC within Trim Galore
  tg_adapter        = null       // Manually provide adapter sequence (null = auto-detect)
  tg_min_length    = 20         // Discard reads shorter than this after trimming
  tg_stringency    = 1          // Overlap with adapter sequence required to trim
  tg_error_rate    = 0.1        // Maximum allowed error rate (mismatches / length)
  tg_clip_r1       = 0          // Remove N bp from the 5 end of R1
  tg_clip_r2       = 0          // Remove N bp from the 5 end of R2
  tg_three_prime_clip_r1 = 0    // Remove N bp from the 3 end of R1
  tg_three_prime_clip_r2 = 0    // Remove N bp from the 3 end of R2

  // QC Skip Flags
  skip_fastqc_raw        = false
  skip_multiqc_raw       = false
  skip_fastqc_trimmed    = false
  skip_multiqc_trimmed   = false
  skip_fastqc_ribo       = false
  skip_multiqc_ribo      = false

  // resources / behavior
  max_cpus   = 56
  max_mem    = 248.GB
  max_time   = 24.h

  // containers / env
  use_docker = false
  use_conda  = true       // set true if you prefer conda
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = "$baseDir/singularity_cache"
  // This ensures that all singularity runs get the GPU flag
  runOptions = '--nv'
}

executor {
  $local {
    cpus = params.max_cpus
    memory = params.max_mem
  }
}

process {
  containerOptions = { workflow.containerEngine == 'singularity' ? '--nv' : '' }
  cpus    = { params.max_cpus }
  memory  = { params.max_mem }
  time    = { params.max_time }

  // Retry once; if it still fails, ignore that task and continue
  errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
  maxRetries    = 1

        // Specifically give RiboDetector access to the GPU
        withName: 'RIBODETECTOR' {
            // Ensure container engine is not trying to pull
            container = "${baseDir}/ribodetector.sif"
            maxForks = 1
            containerOptions = '--nv'
            cpus = 16
            memory = 20.GB
        }
        // Set for manual override
        withName: 'SORTMERNA' {
            cpus = 56
            memory = 200.GB
        }

        withName: 'CHECK_GPU' {
            container = 'nvidia/cuda:11.7.1-base-ubuntu22.04'
            containerOptions = { workflow.containerEngine == 'singularity' ? '--nv' : '--gpus all' }
        }

        // Specifically give Parabricks access to the GPU
        withName: 'PARABRICKS_RNA' {
            containerOptions = '--nv'
            cpus = 16
            memory = 64.GB
        }

        // STAR alignment settings
        withName: 'STAR_ALIGN' {
            cpus = 16
            memory = 64.GB
        }

        // featureCounts settings
        withName: 'FEATURECOUNTS' {
            cpus = 8
            memory = '16 GB'
        }

    // DIM WARNINGS: Register optional processes to silence "no process matching" warnings
    withName: SORTMERNA {
        // Dummy entry to silence warning
    }
    withName: PARABRICKS_RNA {
        // Dummy entry to silence warning
    }
}

profiles {
  // Default local run without containers
  local {
    process.executor = 'local'
    docker.enabled   = false
    singularity.enabled = false
    conda.enabled    = params.use_conda
  }

  // Docker on local or laptop/workstation
  docker {
    process.executor = 'local'
    docker.enabled   = true
    docker.runOptions = '-u $(id -u):$(id -g)' // avoid root-owned files
    singularity.enabled = false
    conda.enabled    = params.use_conda
  }

  // Singularity (common on HPC)
  singularity {
    process.executor = 'local'
    docker.enabled   = false
    singularity.enabled = true
    singularity.autoMounts = true
    // This globally ensures NVIDIA support is available for all containers
    singularity.runOptions = '--nv'
    conda.enabled    = params.use_conda
  }

  // SLURM cluster with Singularity
  slurm {
    includeConfig 'conf/slurm.config'
  }

    // Use this profile to mix Singularity (for standard tools) and local Conda (for GPU)
    gpu_conda {
      process.executor = 'local'
      conda.enabled = true
      singularity.enabled = true
      singularity.autoMounts = true
    }
}

// Global trace/reporting - Moving them to a subfolder
def timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

trace {
  enabled = true
  file    = "${params.outdir}/pipeline_info/trace_${timestamp}.txt"
}
report {
  enabled = true
  file    = "${params.outdir}/pipeline_info/report_${timestamp}.html"
}
timeline {
  enabled = true
  file    = "${params.outdir}/pipeline_info/timeline_${timestamp}.html"
}
dag {
  enabled = true
  file    = "${params.outdir}/pipeline_info/dag_${timestamp}.html"
}
